{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tauri: dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "tauri", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/desktop-app"
      },
      "problemMatcher": []
    },
    {
      "label": "tauri: build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "tauri", "build"],
      "options": {
        "cwd": "${workspaceFolder}/desktop-app"
      },
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "dependsOn": "npm: compile",
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
