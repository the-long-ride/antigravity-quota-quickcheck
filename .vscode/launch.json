{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Tauri Desktop App",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/desktop-app",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "tauri", "dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "Run VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: watch"
    }
  ]
}
