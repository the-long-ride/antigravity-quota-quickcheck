{
  "name": "antigravity-quota-quickcheck",
  "displayName": "Antigravity Quota Quickcheck",
  "description": "Monitor your Google AI model quotas and credit balance directly from your Antigravity status bar with 1 click or hovering.",
  "version": "1.1.1",
  "publisher": "the-long-ride",
  "icon": "assets/icons/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-long-ride/antigravity-quota-quickcheck.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-quota.check",
        "title": "Check Antigravity Quota & Google AI Credits"
      },
      {
        "command": "antigravity-quota.setInterval",
        "title": "Set Quota Refresh Interval"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}
