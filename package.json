{
  "name": "antigravity-quota-quickcheck",
  "displayName": "Antigravity Quota Quickcheck",
  "description": "Check Antigravity quota from the status bar",
  "version": "1.1.0",
  "publisher": "the-long-ride",
  "icon": "assets/icons/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/local/antigravity-quota-quickcheck.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-quota.check",
        "title": "Check Antigravity Quota"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}
